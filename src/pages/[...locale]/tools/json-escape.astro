---
import JsonEscape from '@/components/tools/JsonEscape.tsx'
import { H1, Lead } from '@/components/ui/typography'
import { i18next, t } from '@/i18n/ui'
import BaseLayout from '@/layouts/BaseLayout.astro'
import { getI18nStaticPaths } from '@/lib/i18n-utils'

export async function getStaticPaths() {
  return getI18nStaticPaths()
}

const locale = Astro.params.locale ?? 'en'
i18next.changeLanguage(locale)

const labels = {
  escape: t('tools.jsonEscape.escape'),
  unescape: t('tools.jsonEscape.unescape'),
  input: t('tools.jsonEscape.input'),
  output: t('tools.jsonEscape.output'),
  inputPlaceholder: t('tools.jsonEscape.inputPlaceholder'),
  escapedPlaceholder: t('tools.jsonEscape.escapedPlaceholder'),
  unescapedPlaceholder: t('tools.jsonEscape.unescapedPlaceholder'),
  direction: t('tools.jsonEscape.direction'),
  bothDirections: t('tools.jsonEscape.bothDirections'),
  example: t('tools.jsonEscape.example'),
  clear: t('tools.clear'),
  swap: t('tools.swap'),
  copy: t('tools.copy'),
  copied: t('tools.copied'),
  errorInvalidJson: t('tools.jsonEscape.errorInvalidJson'),
  modeHint: t('tools.jsonEscape.modeHint'),
}
---

<BaseLayout
  title={t('tools.jsonEscape.name')}
  breadcrumb={{
    overrides: [
      {
        href: `/${locale}/tools/`,
        label: t('nav.tools'),
      },
      {
        href: `/${locale}/tools/json-escape/`,
        label: t('nav.jsonEscape'),
      },
    ],
  }}
>
  <H1>{t('tools.jsonEscape.name')}</H1>
  <Lead className="mt-6">{t('tools.jsonEscape.description')}</Lead>

  <div class="mt-8">
    <JsonEscape labels={labels} client:load />
  </div>

  <p class="mt-6">
    <a
      href={`/${locale}/tools/`}
      class="text-sm text-muted-foreground underline-offset-2 hover:underline"
    >
      ← {t('tools.backToList')}
    </a>
  </p>
</BaseLayout>